{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "rootDir": ".",
    "types": []
  },
  "include": [
    "src/**/*.ts",
    "remotion/**/*.tsx",
    "remotion/**/*.ts",
    "remotion.config.ts",
    "editor/**/*.tsx",
    "editor/**/*.ts"
  ]
}
