{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/music-analysis-video/project.schema.json",
  "title": "MusicAnalysisVideoProject",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "meta", "sync", "key", "measures"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "description": "Bump when breaking or migrating project JSON shape.",
      "pattern": "^[0-9]+(\\.[0-9]+){0,2}$",
      "examples": ["2"]
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "audioPath"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "artist": { "type": "string" },
        "audioPath": {
          "type": "string",
          "description": "Path to audio relative to project root or the JSON file location (choose one convention in the app)."
        },
        "audioStartOffsetSec": {
          "type": "number",
          "minimum": 0,
          "description": "Trim this many seconds from the start of the audio file before sync (optional)."
        },
        "bpmDisplayHint": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "Optional UI-only hint when anchors carry the real timing."
        }
      }
    },
    "sync": {
      "type": "object",
      "additionalProperties": false,
      "required": ["anchors"],
      "properties": {
        "anchors": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["beat", "timeSec"],
            "properties": {
              "beat": { "type": "number", "description": "Musical beat index from project origin (float allowed)." },
              "timeSec": {
                "type": "number",
                "minimum": 0,
                "description": "Corresponding time in seconds in the (trimmed) audio timeline."
              }
            }
          }
        },
        "extrapolation": {
          "type": "string",
          "enum": ["clamp", "extend"],
          "default": "clamp",
          "description": "Outside anchor range: clamp to endpoints or extend first/last segment slope."
        }
      }
    },
    "key": {
      "type": "object",
      "additionalProperties": false,
      "required": ["default"],
      "properties": {
        "default": { "type": "string", "description": "Global or starting key label (e.g., 'C Major')." }
      }
    },
    "measures": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["index", "timeSignature", "events"],
        "properties": {
          "index": { "type": "integer", "minimum": 1 },
          "timeSignature": {
            "type": "object",
            "additionalProperties": false,
            "required": ["upper", "lower"],
            "properties": {
              "upper": { "type": "integer", "minimum": 1 },
              "lower": { "type": "integer", "enum": [1, 2, 4, 8, 16, 32] }
            }
          },
          "section": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "label"],
            "properties": {
              "id": { "type": "string" },
              "label": { "type": "string" },
              "comment": { "type": "string" }
            }
          },
          "events": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["beatOffset", "type", "value"],
              "properties": {
                "beatOffset": { "type": "number", "minimum": 0 },
                "type": {
                  "type": "string",
                  "enum": ["chord", "key_change", "bpm_change", "comment", "emotion", "section"]
                },
                "value": {
                  "oneOf": [
                    { "type": "string" },
                    { "type": "number" }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "style": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "themeId": { "type": "string" },
        "primaryColor": { "type": "string", "pattern": "^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})$" },
        "secondaryColor": { "type": "string", "pattern": "^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})$" },
        "footerText": { "type": "string" }
      }
    },
    "export": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "fps": { "type": "integer", "enum": [24, 25, 30, 60] },
        "defaultComposition": { "type": "string", "enum": ["9:16", "16:9"] },
        "outputName": { "type": "string" },
        "crf": { "type": "integer", "minimum": 0, "maximum": 51 },
        "audioBitrate": { "type": "integer", "minimum": 64 },
        "pixelFormat": { "type": "string", "enum": ["yuv420p", "yuv422p", "yuv444p"] }
      }
    }
  }
}
